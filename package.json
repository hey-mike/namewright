{
  "name": "nextjs-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,stripe,inngest -c cyan,magenta,yellow --handle-input npm:dev:next npm:dev:stripe npm:dev:inngest",
    "dev:next": "next dev",
    "dev:stripe": "stripe listen --forward-to http://localhost:3000/api/webhook",
    "dev:inngest": "npx inngest-cli@latest dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@launchdarkly/node-server-sdk": "^9.10.11",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.49.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/kv": "^3.0.0",
    "inngest": "^4.2.4",
    "jose": "^6.2.2",
    "next": "16.2.4",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.2",
    "stripe": "^22.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/pino": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
