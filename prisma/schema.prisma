generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String         @id @default(uuid())
  email     String         @unique
  createdAt DateTime       @default(now())
  reports   ReportRecord[]
}

model ReportRecord {
  id        String   @id // matches R2 reportId
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
