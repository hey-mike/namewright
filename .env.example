# Required — validateEnv throws if any of these are missing at runtime

# Anthropic Claude API — used for inferNiceClass + generateCandidates + synthesiseReport
ANTHROPIC_API_KEY=

# Stripe — Test mode keys for dev, Live mode keys for prod (activate Stripe account first)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Vercel KV / Upstash Redis (auto-populated by `vercel env pull` after linking Storage)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Session JWT signing — MINIMUM 32 characters (HS256 requires a 256-bit key)
# Generate a fresh one with: openssl rand -hex 32
SESSION_SECRET=

# App public URL — used in emails, checkout success_url, Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Optional integrations — each gracefully no-ops when its key is absent

# Cloudflare Turnstile (bot protection on intake form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Signa trademark registry API (Phase 1 — USPTO + EUIPO + WIPO Madrid)
# Without this, checkTrademark returns uncertain for every candidate
SIGNA_API_KEY=

# WhoisJSON — third layer of domain availability signal (DNS + RDAP + WhoisJSON)
# Free tier: 1000 requests/month. Without this, aggregator falls back to DNS + RDAP only
# (more "uncertain" labels on non-.com TLDs)
WHOISJSON_API_KEY=

# LaunchDarkly — gates the euipo-direct-cross-check flag
# When unset, all flags fall back to their default value (flag defaults to OFF).
# LD init has a 5s timeout so it never blocks a serverless cold start
LAUNCHDARKLY_SDK_KEY=

# EUIPO direct API (Phase 2a cross-check on top of Signa for EU/Global briefs)
# Defaults target the sandbox. For production base URLs:
#   EUIPO_AUTH_BASE_URL=https://auth.euipo.europa.eu
#   EUIPO_API_BASE_URL=https://api.euipo.europa.eu
# Apply for production access at dev.euipo.europa.eu (1–2 week approval)
EUIPO_CLIENT_ID=
EUIPO_CLIENT_SECRET=
EUIPO_AUTH_BASE_URL=
EUIPO_API_BASE_URL=

# IP Australia Trade Mark Search API (AU/APAC direct coverage on top of Signa)
# Sign up at portal.api.ipaustralia.gov.au → subscribe to "Australian Trade Mark
# Search API" → copy client_id + client_secret. OAuth2 client_credentials flow.
# Defaults target the sandbox; set both _BASE_URL vars to production after approval:
#   IPAU_AUTH_BASE_URL=https://production.api.ipaustralia.gov.au
#   IPAU_API_BASE_URL=https://production.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1
# Sandbox equivalents:
#   IPAU_AUTH_BASE_URL=https://test.api.ipaustralia.gov.au
#   IPAU_API_BASE_URL=https://test.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1
IPAU_CLIENT_ID=
IPAU_CLIENT_SECRET=
IPAU_AUTH_BASE_URL=
IPAU_API_BASE_URL=

# Sentry error tracking — when unset, @sentry/nextjs is a no-op (conditional import)
SENTRY_DSN=

# Slack alerts — posts to incoming webhook on actionable failures
# (webhook signature invalid, KV save failed, Anthropic credit exhausted, EUIPO token failed)
# Silent no-op when unset — no errors in dev/preview
SLACK_ALERT_WEBHOOK_URL=

# Resend — transactional email (email-me-a-copy feature at paywall)
# Without RESEND_API_KEY, the paywall email-copy feature gracefully no-ops.
# RESEND_FROM_ADDRESS defaults to 'Namewright <onboarding@resend.dev>' if unset;
# for production, use a verified sender from your own domain.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Cron secret — Bearer token for /api/cron/stripe-reconcile
# Generate: openssl rand -hex 32
# Set on Vercel production via: vercel env add CRON_SECRET production
# Vercel Cron auto-injects `Authorization: Bearer $CRON_SECRET` when invoking the endpoint
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Dev-only flags — leave unset in production. These bypass paid APIs for
# local end-to-end testing (Stripe checkout, webhook, email delivery).

# Returns a canned report fixture from src/lib/__fixtures__/dev-report.ts
# instead of calling Anthropic + Signa + EUIPO + WhoisJSON. Each test purchase
# goes from ~$0.25 and 90s to $0 and 200ms. Refuses to run in production
# (NODE_ENV=production + VERCEL_ENV=production) even if set.
# Usage: set to 1 while debugging payment/email flows; unset for real tests.
DEV_MOCK_PIPELINE=
